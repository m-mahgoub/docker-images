# Copy this file to ~/.config/.docker-builder-secrets and fill in values.
# Keep the real file private: chmod 600 ~/.config/.docker-builder-secrets

# Default registry used by build_and_push.sh when -r/--registry is omitted.
DEFAULT_REGISTRY=ghcr

# Directory containing image folders.
IMAGE_ROOT=images

# Builder routing defaults.
# Use local for workstation builds, ssh for a remote builder, or auto to use
# ssh when BUILDER_TARGET is set and local otherwise.
BUILDER_MODE=auto
BUILDER_TARGET=
BUILDER_ENGINE=docker

# Optional AWS EC2 builder launch helper defaults.
AWS_BUILDER_TEMPLATE=DockerBuilderTemplate
AWS_PROFILE_NAME=
AWS_REGION_NAME=

# GHCR settings.
GHCR_OWNER=your-github-org-or-user
GHCR_USER=your-github-username
GHCR_TOKEN=your-github-token-with-package-write-access

# DockerHub settings, optional unless using --registry dockerhub.
DOCKERHUB_USER=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token
